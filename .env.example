# ── HappyCapy Telegram Agent Bot ─────────────────────────────
# Copy this file to .env and fill in your values.

# Telegram bot token (get from @BotFather)
BOT_TOKEN=your_bot_token_here

# Comma-separated Telegram user IDs allowed to use the bot
# Get your ID from @userinfobot on Telegram
AUTHORIZED_USERS=123456789

# AI Gateway API key (auto-detected on HappyCapy platform)
# Only set manually if auto-detection fails
# AI_GATEWAY_API_KEY=

# ── Optional settings ────────────────────────────────────────

# AI Gateway URL (default: HappyCapy AI Gateway)
# AI_GATEWAY_URL=https://ai-gateway.happycapy.ai/api/v1/chat/completions

# Max agent turns per request (default: 50)
# MAX_AGENT_TURNS=50

# Max auto-continue rounds (default: 3, total budget = turns * (1 + continues))
# MAX_AUTO_CONTINUES=3

# AI request timeout in milliseconds (default: 120000 = 2 minutes)
# AI_TIMEOUT_MS=120000

# Platform paths (rarely need changing)
# WORKSPACE_BASE=/home/node/a0/workspace
# PLATFORM_API_BASE=http://localhost:3001/api/sessions
# PLATFORM_URL=https://happycapy.ai
